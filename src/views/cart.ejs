<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/styles.css">
    <style>
        .cart-container {
            max-width: 1100px;
            margin: 2rem auto;
            padding: 0 1rem;
        }

        .cart-container h1 {
            margin-top: 0;
            margin-bottom: 1rem;
            color: #222;
        }

        .cart-error {
            color: #7a1414;
            padding: 0.85rem 1rem;
            background-color: #f9dede;
            border: 1px solid #e7b5b5;
            border-radius: 8px;
            margin-bottom: 1rem;
        }

        .cart-empty {
            text-align: center;
            padding: 2.2rem 1.2rem;
            background-color: #efefef;
            border-radius: 10px;
            box-shadow: 0 6px 18px rgba(0, 0, 0, 0.12);
        }

        .cart-empty a {
            display: inline-block;
            margin-top: 0.9rem;
            padding: 0.55rem 0.9rem;
            background-color: #333;
            color: #fff;
            text-decoration: none;
            border-radius: 6px;
        }

        .cart-items {
            background-color: #fff;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 6px 18px rgba(0, 0, 0, 0.12);
        }

        .cart-item {
            display: flex;
            padding: 1rem;
            border-bottom: 1px solid #e5e5e5;
            align-items: center;
            gap: 1rem;
        }

        .cart-item:last-child {
            border-bottom: none;
        }

        .cart-item-image {
            width: 110px;
            height: 110px;
            object-fit: contain;
            object-position: center;
            background-color: #fff;
            border-radius: 14px;
            padding: 0.3rem;
            box-sizing: border-box;
        }

        .cart-item-info {
            flex: 1;
        }

        .cart-item-name {
            font-size: 1.1rem;
            font-weight: 700;
            margin-bottom: 0.3rem;
            color: #222;
        }

        .cart-item-price {
            color: #333;
            margin-bottom: 0.35rem;
        }

        .cart-item-controls {
            display: flex;
            align-items: center;
            gap: 0.6rem;
        }

        .quantity-input {
            width: 64px;
            padding: 0.45rem;
            border: 1px solid #bbb;
            border-radius: 6px;
            font: inherit;
            background-color: #fff;
        }

        .btn-remove,
        .btn-update,
        .btn-checkout,
        .btn-clear-cart,
        .btn-continue {
            padding: 0.5rem 0.75rem;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 0.95rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .btn-update,
        .btn-checkout {
            background-color: #333;
            color: #fff;
        }

        .btn-continue {
            background-color: #efefef;
            color: #222;
            border: 1px solid #bbb;
        }

        .btn-remove,
        .btn-clear-cart {
            background-color: #00b0b0;
            color: #111;
        }

        .cart-subtotal {
            text-align: right;
            font-size: 1.05rem;
            font-weight: 700;
            padding: 1rem;
            border-top: 1px solid #e5e5e5;
            background-color: #fafafa;
        }

        .cart-summary {
            margin-top: 1rem;
            background-color: #fff;
            border-radius: 10px;
            box-shadow: 0 6px 18px rgba(0, 0, 0, 0.12);
            padding: 1rem;
            text-align: right;
        }

        .cart-total {
            font-size: 1.35rem;
            font-weight: 700;
            margin-bottom: 0.9rem;
            color: #222;
        }

        .cart-actions {
            display: flex;
            gap: 0.6rem;
            justify-content: flex-end;
            flex-wrap: wrap;
        }

        .btn-update:hover,
        .btn-checkout:hover {
            background-color: #1f1f1f;
        }

        .btn-remove:hover,
        .btn-clear-cart:hover {
            background-color: #009898;
        }

        .btn-continue:hover {
            background-color: #e2e2e2;
        }

        @media (max-width: 768px) {
            .cart-item {
                flex-direction: column;
                align-items: flex-start;
            }

            .cart-item-image {
                width: 100%;
                max-width: 220px;
                height: 180px;
            }

            .cart-item-controls {
                width: 100%;
                flex-wrap: wrap;
            }

            .cart-actions {
                justify-content: stretch;
            }

            .btn-remove,
            .btn-update,
            .btn-checkout,
            .btn-clear-cart,
            .btn-continue {
                flex: 1;
                min-width: 150px;
            }
        }
    </style>
</head>
<body>
    <%- include('partials/header') %>

    <div class="cart-container">
        <h1><%= title %></h1>

        <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
            <div class="cart-error">
                <%= errorMessage %>
            </div>
        <% } %>

        <% if (cart.length === 0) { %>
            <div class="cart-empty">
                <h2>Your cart is empty</h2>
                <p>Start shopping to add items to your cart</p>
                <a href="/products">Continue Shopping</a>
            </div>
        <% } else { %>
            <div class="cart-items">
                <% cart.forEach(item => { %>
                    <div class="cart-item">
                        <img src="<%= item.image_url || '/images/placeholder.png' %>" alt="<%= item.name %>" class="cart-item-image">
                        <div class="cart-item-info">
                            <div class="cart-item-name"><%= item.name %></div>
                            <div class="cart-item-price">$<%= parseFloat(item.price).toFixed(2) %> each</div>
                            <div class="cart-item-price">Subtotal: $<%= parseFloat(item.subtotal).toFixed(2) %></div>
                        </div>
                        <div class="cart-item-controls">
                            <input type="number" min="1" max="5" value="<%= item.quantity %>" class="quantity-input" id="qty-<%= item.id %>" data-item-id="<%= item.id %>">
                            <button class="btn-update" onclick="updateQuantity(<%= item.id %>)">Update</button>
                            <button class="btn-remove" onclick="removeItem(<%= item.id %>)">Remove</button>
                        </div>
                    </div>
                <% }); %>
            </div>

            <div class="cart-subtotal">
                Subtotal: $<%= parseFloat(total).toFixed(2) %>
            </div>

            <div class="cart-summary">
                <div class="cart-total">
                    Total: $<%= parseFloat(total).toFixed(2) %>
                </div>
                <div class="cart-actions">
                    <a href="/products" class="btn-continue">Continue Shopping</a>
                    <button class="btn-checkout" onclick="proceedToCheckout()">Proceed to Checkout</button>
                    <button class="btn-clear-cart" onclick="clearCart()">Clear Cart</button>
                </div>
            </div>
        <% } %>
    </div>

    <%- include('partials/footer') %>

    <script>
        const MAX_CART_ITEM_QUANTITY = 5;

        function removeItem(itemId) {
            if (confirm('Are you sure you want to remove this item?')) {
                fetch(`/api/cart/items/${itemId}`, {
                    method: 'DELETE'
                })
                .then(response => response.json())
                .then(data => {
                    location.reload();
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Failed to remove item');
                });
            }
        }

        function updateQuantity(itemId) {
            const quantity = parseInt(document.getElementById(`qty-${itemId}`).value);
            
            if (quantity <= 0) {
                alert('Quantity must be greater than 0');
                return;
            }

            if (quantity > MAX_CART_ITEM_QUANTITY) {
                alert(`You can only have up to ${MAX_CART_ITEM_QUANTITY} of one item in your cart.`);
                return;
            }

            fetch(`/api/cart/items/${itemId}`, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ quantity })
            })
            .then(async response => ({
                ok: response.ok,
                data: await response.json()
            }))
            .then(data => {
                if (!data.ok) {
                    throw new Error(data.data?.error || 'Failed to update quantity');
                }
                location.reload();
            })
            .catch(error => {
                console.error('Error:', error);
                alert(error.message || 'Failed to update quantity');
            });
        }

        function clearCart() {
            if (confirm('Are you sure you want to clear your entire cart?')) {
                fetch('/api/cart', {
                    method: 'DELETE'
                })
                .then(response => response.json())
                .then(data => {
                    location.reload();
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Failed to clear cart');
                });
            }
        }

        function proceedToCheckout() {
            alert('Checkout functionality coming soon!');
            // In a real application, this would redirect to a checkout page
        }
    </script>
</body>
</html>
