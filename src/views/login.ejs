<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <title><%= title %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <script src="/js/header.js" defer></script>

    <link rel="stylesheet" href="/css/styles.css" />
    <link rel="stylesheet" href="/css/signin.css" />
</head>

<body class="auth-page">
    <%- include("./partials/header") %>

    <main class="auth-main">
        <section class="auth-card" aria-labelledby="login-title">
            <h1 id="login-title">Welcome Back</h1>
            <p class="auth-subtitle">Sign in to continue browsing products and managing your account.</p>
            <% if (authMessage) { %>
                <p class="auth-message"><%= authMessage %></p>
            <% } %>

            <form class="auth-form" method="post" action="/login" autocomplete="on">
                <label for="username">Username</label>
                <input id="username" type="text" name="username" placeholder="Enter your username" required />

                <label for="password">Password</label>
                <input id="password" type="password" name="password" placeholder="Enter your password" required />

                <div class="auth-options">
                    <label class="remember-me">
                        <input type="checkbox" name="remember" />
                        Remember me
                    </label>
                    <a href="#" class="auth-link">Forgot password?</a>
                </div>

                <button class="auth-button" type="submit">Sign In</button>
            </form>

            <p class="auth-alt-action">
                New here?
                <a href="/register" class="auth-link">Create an account</a>
            </p>
        </section>
    </main>

    <%- include("./partials/footer") %>
</body>
</html>