<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <title><%= title %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <script src="/js/header.js" defer></script>

    <link rel="stylesheet" href="/css/styles.css" />
    <link rel="stylesheet" href="/css/signin.css" />
</head>

<body class="auth-page">
    <%- include("./partials/header") %>

    <main class="auth-main">
        <section class="auth-card" aria-labelledby="login-title">
            <h1 id="login-title">Welcome Back</h1>
            <p class="auth-subtitle">Sign in to continue browsing products and managing your account.</p>
            <% if (authMessage) { %>
                <p class="auth-message"><%= authMessage %></p>
            <% } %>

            <form class="auth-form" method="post" action="/login" autocomplete="on">
                <label for="username">Username</label>
                <input id="username" type="text" name="username" placeholder="Enter your username" required />

                <label for="password">Password</label>
                <input id="password" type="password" name="password" placeholder="Enter your password" required />

                <div class="auth-options">
                    <label class="remember-me">
                        <input type="checkbox" name="remember" />
                        Remember me
                    </label>
                    <a href="#" class="auth-link">Forgot password?</a>
                </div>

                <button class="auth-button" type="submit">Sign In</button>
            </form>

            <p class="auth-alt-action">
                New here?
                <a href="/register" class="auth-link">Create an account</a>
            </p>
            <a href="/auth/google" class="google-signin-link">
                <button class="google-signin-btn" type="button">
                    <svg class="google-icon" viewBox="0 0 24 24" width="20" height="20" xmlns="http://www.w3.org/2000/svg">
                        <g transform="matrix(1, 0, 0, 1, 27.009766, -39.238281)">
                            <path fill="#4285F4" d="M -3.264 51.509 C -3.264 50.719 -3.334 49.969 -3.454 49.239 L -14.754 49.239 L -14.754 53.749 L -8.284 53.749 C -8.574 55.229 -9.424 56.479 -10.684 57.329 L -10.684 60.329 L -6.824 60.329 C -4.564 58.239 -3.264 55.159 -3.264 51.509 Z" />
                            <path fill="#34A853" d="M -14.754 63.239 C -11.514 63.239 -8.804 62.159 -6.824 60.329 L -10.684 57.329 C -11.764 58.049 -13.134 58.489 -14.754 58.489 C -17.884 58.489 -20.534 56.379 -21.484 53.529 L -25.464 53.529 L -25.464 56.619 C -23.494 60.539 -19.444 63.239 -14.754 63.239 Z" />
                            <path fill="#FBBC05" d="M -21.484 53.529 C -21.734 52.809 -21.864 52.039 -21.864 51.249 C -21.864 50.459 -21.724 49.699 -21.484 48.979 L -21.484 45.889 L -25.464 45.889 C -26.284 47.799 -26.754 49.889 -26.754 51.249 C -26.754 52.609 -26.284 54.699 -25.464 56.619 L -21.484 53.529 Z" />
                            <path fill="#EA4335" d="M -14.754 43.989 C -13.044 43.989 -11.404 44.599 -10.154 45.789 L -6.734 42.369 C -8.804 40.429 -11.514 39.239 -14.754 39.239 C -19.444 39.239 -23.494 41.939 -25.464 45.889 L -21.484 48.979 C -20.534 46.129 -17.884 43.989 -14.754 43.989 Z" />
                        </g>
                    </svg>
                    <span>Sign in with Google</span>
                </button>
            </a>

            <a href="/auth/discord" class="discord-signin-link">
                <button class="discord-signin-btn" type="button">
                    <svg class="discord-icon" viewBox="0 0 127.14 96.36" width="20" height="20" aria-hidden="true" focusable="false">
                        <path fill="currentColor" d="M107.7,8.07A105.15,105.15,0,0,0,81.47,0a72.06,72.06,0,0,0-3.36,6.83,97.68,97.68,0,0,0-29.11,0A72.37,72.37,0,0,0,45.64,0,105.89,105.89,0,0,0,19.39,8.09C2.79,32.65-1.71,56.6.54,80.21h0A105.73,105.73,0,0,0,32.71,96.36a77.7,77.7,0,0,0,6.89-11.25,68.42,68.42,0,0,1-10.84-5.18c.91-.66,1.8-1.35,2.66-2.06a75.26,75.26,0,0,0,64.3,0c.87.71,1.76,1.4,2.67,2.06a68.68,68.68,0,0,1-10.86,5.19,77,77,0,0,0,6.89,11.24A105.25,105.25,0,0,0,126.6,80.22C129.24,52.84,122.09,29.11,107.7,8.07ZM42.45,65.69c-6.27,0-11.4-5.73-11.4-12.8S36,40.09,42.45,40.09s11.51,5.78,11.4,12.8C53.85,60,48.87,65.69,42.45,65.69Zm42.24,0c-6.27,0-11.4-5.73-11.4-12.8s5-12.8,11.4-12.8,11.51,5.78,11.4,12.8C96.09,60,91.12,65.69,84.69,65.69Z"/>
                    </svg>
                    <span>Sign in with Discord</span>
                </button>
            </a>
        </section>
    </main>

    <%- include("./partials/footer") %>
</body>
</html>